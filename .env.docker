# Application settings
NODE_ENV=production
PORT=5000

# Database settings
DB_PATH=/app/data/database.sqlite
DB_BACKUP_INTERVAL=3600000

# Logging settings
LOG_LEVEL=info
LOG_FILE=/app/logs/combined.log

# Security settings
JWT_SECRET=your-production-secret-here
SESSION_SECRET=your-session-secret-here

# Hardware settings
HARDWARE_SIMULATION=true
CAN_INTERFACE=vcan0

# Redis settings (if used)
REDIS_HOST=redis
REDIS_PORT=6379
{
  "dashboard": {
    "id": null,
    "title": "SRE Error Budget Tracking",
    "tags": ["sre", "error-budget", "reliability"],
    "style": "dark",
    "timezone": "browser", 
    "refresh": "1m",
    "time": {
      "from": "now-30d",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Error Budget Overview",
        "type": "table",
        "targets": [
          {
            "expr": "error_budget_consumption_robot_commands",
            "legendFormat": "Robot Control",
            "format": "table"
          },
          {
            "expr": "error_budget_consumption_api",
            "legendFormat": "API Services",
            "format": "table"
          },
          {
            "expr": "error_budget_consumption_websocket",
            "legendFormat": "WebSocket",
            "format": "table"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {
              "displayMode": "gradient-gauge",
              "orientation": "horizontal"
            },
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 50},
                {"color": "orange", "value": 75},
                {"color": "red", "value": 90}
              ]
            }
          }
        },
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Robot Control Error Budget Burn Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(robot_commands_total{status=\"failed\"}[5m]) / rate(robot_commands_total[5m]) * 100",
            "legendFormat": "Current Error Rate"
          },
          {
            "expr": "1.0",
            "legendFormat": "Error Budget Allocation (1%)"
          },
          {
            "expr": "0.1",
            "legendFormat": "Fast Burn Threshold (10x SLO)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {
              "drawStyle": "line"
            }
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10}
      },
      {
        "id": 3,
        "title": "API Error Budget Burn Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(http_requests_total{status=~\"4..|5..\"}[5m]) / rate(http_requests_total[5m]) * 100",
            "legendFormat": "Current Error Rate"
          },
          {
            "expr": "0.1",
            "legendFormat": "Error Budget Allocation (0.1%)"
          },
          {
            "expr": "0.01",
            "legendFormat": "Fast Burn Threshold (10x SLO)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {
              "drawStyle": "line"
            }
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10}
      },
      {
        "id": 4,
        "title": "Error Budget Burn Rate Alerts",
        "type": "alertlist",
        "targets": [
          {
            "expr": "ALERTS{alertname=~\".*ErrorBudget.*\"}"
          }
        ],
        "options": {
          "alertName": "",
          "dashboardAlerts": false,
          "groupBy": ["alertname"],
          "groupMode": "default",
          "maxItems": 20,
          "query": "",
          "showOptions": "current",
          "sortOrder": 1,
          "tags": []
        },
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 18}
      },
      {
        "id": 5,
        "title": "Time to Exhaust Error Budget",
        "type": "stat",
        "targets": [
          {
            "expr": "prediction_linear(error_budget_consumption_robot_commands[1h], 3600) > 100",
            "legendFormat": "Robot Control"
          },
          {
            "expr": "prediction_linear(error_budget_consumption_api[1h], 3600) > 100", 
            "legendFormat": "API Services"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "displayMode": "list"
            }
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 18}
      },
      {
        "id": 6,
        "title": "SLO Compliance Trend (30 days)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "avg_over_time(robot_command_success_rate[24h])",
            "legendFormat": "Robot Command Success Rate"
          },
          {
            "expr": "avg_over_time(api_success_rate[24h])",
            "legendFormat": "API Success Rate"
          },
          {
            "expr": "99.0",
            "legendFormat": "Robot SLO (99%)"
          },
          {
            "expr": "99.9",
            "legendFormat": "API SLO (99.9%)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 98,
            "max": 100
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 18}
      },
      {
        "id": 7,
        "title": "Error Budget Policy Status",
        "type": "table",
        "targets": [
          {
            "expr": "label_replace(error_budget_consumption_robot_commands > 0, \"service\", \"robot_control\", \"\", \"\")",
            "format": "table"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {},
              "indexByName": {},
              "renameByName": {
                "Value": "Consumption %"
              }
            }
          },
          {
            "id": "fieldLookup",
            "options": {
              "lookupField": "Consumption %",
              "outputField": "Policy",
              "mapping": [
                {"input": "0-25", "output": "🟢 Normal Development"},
                {"input": "25-50", "output": "🟡 Increased Monitoring"},
                {"input": "50-75", "output": "🟠 Focus on Reliability"},
                {"input": "75-90", "output": "🔴 Feature Freeze"},
                {"input": "90-100", "output": "🚨 Emergency Response"}
              ]
            }
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 26}
      },
      {
        "id": 8,
        "title": "Historical Error Budget Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "error_budget_consumption_robot_commands",
            "legendFormat": "Robot Control Budget Used"
          },
          {
            "expr": "error_budget_consumption_api",
            "legendFormat": "API Budget Used"
          },
          {
            "expr": "50",
            "legendFormat": "Warning Threshold"
          },
          {
            "expr": "75",
            "legendFormat": "Critical Threshold"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 26}
      },
      {
        "id": 9,
        "title": "Top Error Contributors",
        "type": "table",
        "targets": [
          {
            "expr": "topk(10, increase(robot_command_failures_by_type[1h]))",
            "format": "table",
            "legendFormat": "Robot Command Failures"
          },
          {
            "expr": "topk(10, increase(http_requests_total{status=~\"4..|5..\"}[1h]))",
            "format": "table", 
            "legendFormat": "API Failures"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true, "__name__": true},
              "indexByName": {},
              "renameByName": {
                "Value": "Error Count",
                "error_type": "Error Type",
                "endpoint": "Endpoint",
                "status": "Status Code"
              }
            }
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 34}
      }
    ],
    "annotations": {
      "list": [
        {
          "name": "Error Budget Alerts",
          "datasource": "prometheus",
          "enable": true,
          "expr": "ALERTS{alertname=~\".*ErrorBudget.*\"}",
          "iconColor": "orange",
          "textFormat": "{{alertname}}: {{summary}}"
        },
        {
          "name": "Incidents",
          "datasource": "prometheus",
          "enable": true,
          "expr": "increase(incident_count[5m])",
          "iconColor": "red",
          "textFormat": "Incident: {{incident_type}}"
        }
      ]
    },
    "templating": {
      "list": [
        {
          "name": "service",
          "type": "query",
          "query": "label_values(error_budget_consumption, service)",
          "refresh": 1,
          "includeAll": true,
          "multi": true
        }
      ]
    }
  }
}
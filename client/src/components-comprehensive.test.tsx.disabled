  describe('Accessibility and Keyboard Navigation', () => {
    test('tab buttons have proper ARIA labels', async () => {
      render(<MockApp />);
      
      const tabs = ['manual', 'gcode', 'replay', 'config', 'advanced-config', 'monitoring'];
      tabs.forEach(tabId => {
        const tabButton = screen.getByTestId(`tab-${tabId}`);
        expect(tabButton).toHaveAttribute('aria-label');
      });
    });

    test('supports keyboard navigation', async () => {
      render(<MockApp />);
      
      // Tab through elements
      const tabManual = screen.getByTestId('tab-manual');
      const tabGCode = screen.getByTestId('tab-gcode');
      
      tabManual.focus();
      expect(tabManual).toHaveFocus();
      
      // Simulate Tab key press
      await user.keyboard('{Tab}');
      expect(tabGCode).toHaveFocus();
    });

    test('supports Enter key activation', async () => {
      render(<MockApp />);
      
      const tabGCode = screen.getByTestId('tab-gcode');
      tabGCode.focus();
      
      await user.keyboard('{Enter}');
      await waitFor(() => {
        expect(screen.getByTestId('gcode-control')).toBeInTheDocument();
      });
    });
  });

  describe('Error Handling and Edge Cases', () => {
    test('handles missing configuration gracefully', () => {
      const MockAppWithoutConfig = () => {
        const [config] = React.useState(null);
        return (
          <div data-testid="app-no-config">
            <MockManualControl config={config} socket={null} />
          </div>
        );
      };

      expect(() => render(<MockAppWithoutConfig />)).not.toThrow();
    });

    test('handles empty position and group arrays', () => {
      const MockAppWithEmptyData = () => {
        const [positions] = React.useState([]);
        const [groups] = React.useState([]);
        return (
          <div data-testid="app-empty-data">
            <MockPositionReplay 
              positions={positions} 
              groups={groups} 
              socket={null}
              config={mockRobotConfig}
            />
          </div>
        );
      };

      render(<MockAppWithEmptyData />);
      expect(screen.getByTestId('app-empty-data')).toBeInTheDocument();
    });

    test('handles socket connection errors gracefully', () => {
      const MockAppWithSocketError = () => {
        const [socket] = React.useState(null);
        return (
          <div data-testid="app-socket-error">
            <MockGCodeControl socket={socket} />
          </div>
        );
      };

      expect(() => render(<MockAppWithSocketError />)).not.toThrow();
    });
  });

  describe('Integration and State Management', () => {
    test('maintains state across tab switches', async () => {
      render(<MockApp />);
      
      // Go to configuration tab and verify robot type
      await user.click(screen.getByTestId('tab-config'));
      const robotTypeSelect = screen.getByTestId('robot-type');
      expect(robotTypeSelect).toHaveValue('6-axis');
      
      // Switch to another tab and back
      await user.click(screen.getByTestId('tab-manual'));
      await user.click(screen.getByTestId('tab-config'));
      
      // Robot type should still be the same
      expect(screen.getByTestId('robot-type')).toHaveValue('6-axis');
    });

    test('updates connection status across components', () => {
      render(<MockApp />);
      
      // Connection status should be visible in header
      expect(screen.getByTestId('connection-status')).toHaveTextContent('Connected');
      
      // Switch to monitoring tab
      fireEvent.click(screen.getByTestId('tab-monitoring'));
      
      // Connection status should also be shown in monitoring
      waitFor(() => {
        expect(screen.getByTestId('connection-status')).toHaveTextContent('Connection: Connected');
      });
    });
  });
});
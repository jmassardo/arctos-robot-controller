        ))}
    </div>
    <div data-testid="save-section">
      <button data-testid="save-config">Save Configuration</button>
      <button data-testid="reset-config">Reset to Defaults</button>
      <button data-testid="export-config">Export Configuration</button>
      <button data-testid="import-config">Import Configuration</button>
    </div>
    <div data-testid="save-status">
      {/* Save status messages would appear here */}
    </div>
  </div>
);


const MockConfiguration = ({ config, onConfigUpdate }: any) => (
  <div data-testid="configuration">
    <h2>Configuration</h2>
    <div data-testid="robot-settings">
      <h3>Robot Settings</h3>
      <div data-testid="robot-type-section">
        <label htmlFor="robot-type">Robot Type:</label>
        <select data-testid="robot-type" id="robot-type" defaultValue={config?.robotType}>
          <option value="6-axis">6-Axis Industrial Robot</option>
          <option value="4-axis">4-Axis SCARA Robot</option>
          <option value="delta">Delta Robot</option>
          <option value="cartesian">Cartesian Robot</option>
        </select>
      </div>
      <div data-testid="communication-section">
        <label htmlFor="protocol">Communication Protocol:</label>
        <select data-testid="protocol" id="protocol" defaultValue={config?.communicationProtocol}>
          <option value="can">CAN Bus</option>
          <option value="serial">Serial</option>
          <option value="rs485">RS485</option>
          <option value="ethernet">Ethernet</option>
        </select>
      </div>
    </div>
    <div data-testid="axis-limits">
      <h3>Axis Limits</h3>
      {config && Object.entries(config.axes.limits).map(([axis, limits]: [string, any]) => (
        <div key={axis} data-testid={`axis-limit-${axis}`}>
          <label>{axis}:</label>
          <input 
            type="number" 
            data-testid={`${axis}-min`} 

// Main App Component for Testing
const MockApp = () => {
  const [activeTab, setActiveTab] = React.useState('manual');
  const [config, setConfig] = React.useState(mockRobotConfig);
  const [positions, setPositions] = React.useState(mockPositions);
  const [groups, setGroups] = React.useState(mockGroups);
  const [connectionStatus, setConnectionStatus] = React.useState('connected');
  const [socket] = React.useState({ on: jest.fn(), emit: jest.fn(), off: jest.fn() });

  const renderTabContent = () => {
    switch(activeTab) {
      case 'manual':
        return <MockManualControl config={config} socket={socket} />;
      case 'gcode':
        return <MockGCodeControl socket={socket} />;
      case 'replay':
        return <MockPositionReplay 
          positions={positions} 
          groups={groups} 
          socket={socket} 
          config={config} 
        />;
      case 'config':
        return <MockConfiguration config={config} onConfigUpdate={setConfig} />;
      case 'advanced-config':
        return <MockAdvancedConfiguration config={config} onConfigUpdate={setConfig} />;
      case 'monitoring':
        return <MockMonitoringDashboard />;
      default:
        return <div data-testid="unknown-tab">Unknown tab</div>;
    }
  };

  const tabs = [
    { id: 'manual', label: 'Manual Control', icon: '🎮' },
    { id: 'gcode', label: 'G-Code Control', icon: '📝' },
    { id: 'replay', label: 'Position Replay', icon: '▶️' },
    { id: 'config', label: 'Configuration', icon: '⚙️' },
    { id: 'advanced-config', label: 'Advanced Config', icon: '🔧' },
    { id: 'monitoring', label: 'Monitoring', icon: '📊' }
  ];

  return (
    <BrowserRouter>
      <div data-testid="app" className="container">
        <header data-testid="header">
          <div data-testid="header-content">
            <h1>Arctos Robot Controller</h1>
            <div data-testid="connection-status" className={`status-indicator status-${connectionStatus}`}>
              {connectionStatus === 'connected' ? 'Connected' : 'Disconnected'}
            </div>
            <div data-testid="user-info">
              <span data-testid="username">{mockAuth.state.user.username}</span>
              <span data-testid="user-role">{mockAuth.state.user.role.toUpperCase()}</span>
              <button data-testid="logout-btn" onClick={mockAuth.logout}>Sign Out</button>
            </div>
          </div>
        </header>

        <nav data-testid="tab-navigation" className="nav-tabs">
          {tabs.map(tab => (
            <button
              key={tab.id}
              data-testid={`tab-${tab.id}`}
              className={`nav-tab ${activeTab === tab.id ? 'active' : ''}`}
              onClick={() => setActiveTab(tab.id)}
              aria-label={`Switch to ${tab.label} tab`}
            >
              <span className="tab-icon">{tab.icon}</span>
              <span className="tab-label">{tab.label}</span>
            </button>
          ))}
        </nav>

        <main data-testid="main-content" className="tab-content">
          {renderTabContent()}
        </main>

        <footer data-testid="footer">
          <div data-testid="system-status">
            System Status: Operational
          </div>
        </footer>
      </div>
    </BrowserRouter>
  );
};

// Test Suite
describe('Arctos Robot Controller Frontend - Comprehensive Component Tests', () => {
  const user = userEvent.setup();

  beforeEach(() => {
    // Reset all mocks before each test
    jest.clearAllMocks();
    
    // Mock console methods to reduce test noise
    global.console = {
      ...console,
      log: jest.fn(),
      error: jest.fn(),
      warn: jest.fn(),
    };

    // Reset window location
    Object.defineProperty(window, 'location', {
      value: { reload: jest.fn() },
      writable: true,
    });
  });

  describe('Application Structure and Navigation', () => {
    test('renders complete application structure', async () => {
      render(<MockApp />);
      
      // Main structure elements
      expect(screen.getByTestId('app')).toBeInTheDocument();
      expect(screen.getByTestId('header')).toBeInTheDocument();
      expect(screen.getByTestId('tab-navigation')).toBeInTheDocument();
      expect(screen.getByTestId('main-content')).toBeInTheDocument();
      expect(screen.getByTestId('footer')).toBeInTheDocument();

      // Header elements
      expect(screen.getByText('Arctos Robot Controller')).toBeInTheDocument();
      expect(screen.getByTestId('connection-status')).toBeInTheDocument();
      expect(screen.getByTestId('user-info')).toBeInTheDocument();

      // Navigation tabs
      const expectedTabs = ['manual', 'gcode', 'replay', 'config', 'advanced-config', 'monitoring'];
      expectedTabs.forEach(tabId => {
        expect(screen.getByTestId(`tab-${tabId}`)).toBeInTheDocument();
      });

      // Footer
      expect(screen.getByTestId('system-status')).toBeInTheDocument();
    });

    test('handles tab navigation correctly', async () => {
      render(<MockApp />);
      
      // Initially shows manual control
      expect(screen.getByTestId('manual-control')).toBeInTheDocument();
      expect(screen.getByTestId('tab-manual')).toHaveClass('active');

      // Switch to G-Code Control
      await user.click(screen.getByTestId('tab-gcode'));
      await waitFor(() => {
        expect(screen.getByTestId('gcode-control')).toBeInTheDocument();
        expect(screen.getByTestId('tab-gcode')).toHaveClass('active');
        expect(screen.queryByTestId('manual-control')).not.toBeInTheDocument();
      });

      // Switch to Position Replay
      await user.click(screen.getByTestId('tab-replay'));
      await waitFor(() => {
        expect(screen.getByTestId('position-replay')).toBeInTheDocument();
        expect(screen.getByTestId('tab-replay')).toHaveClass('active');
      });

      // Switch to Configuration
      await user.click(screen.getByTestId('tab-config'));
      await waitFor(() => {
        expect(screen.getByTestId('configuration')).toBeInTheDocument();
        expect(screen.getByTestId('tab-config')).toHaveClass('active');
      });

      // Switch to Advanced Configuration
      await user.click(screen.getByTestId('tab-advanced-config'));
      await waitFor(() => {
        expect(screen.getByTestId('advanced-configuration')).toBeInTheDocument();
        expect(screen.getByTestId('tab-advanced-config')).toHaveClass('active');
      });

      // Switch to Monitoring
      await user.click(screen.getByTestId('tab-monitoring'));
      await waitFor(() => {
        expect(screen.getByTestId('monitoring-dashboard')).toBeInTheDocument();
        expect(screen.getByTestId('tab-monitoring')).toHaveClass('active');
      });
    });

    test('displays connection status correctly', () => {
      render(<MockApp />);
      
      const connectionStatus = screen.getByTestId('connection-status');
      expect(connectionStatus).toHaveTextContent('Connected');
      expect(connectionStatus).toHaveClass('status-connected');
    });

    test('displays user information', () => {
      render(<MockApp />);
      
      expect(screen.getByTestId('username')).toHaveTextContent('testuser');
      expect(screen.getByTestId('user-role')).toHaveTextContent('ADMIN');
      expect(screen.getByTestId('logout-btn')).toBeInTheDocument();
    });
  });

  describe('Manual Control Component - Complete Coverage', () => {
    beforeEach(async () => {
      render(<MockApp />);
      // Ensure we're on the manual control tab
      await user.click(screen.getByTestId('tab-manual'));
    });

    test('renders all axis controls', () => {
      const expectedAxes = ['axis1', 'axis2', 'axis3', 'axis4', 'axis5', 'axis6'];
      
      expectedAxes.forEach(axis => {
        expect(screen.getByTestId(`axis-${axis}`)).toBeInTheDocument();
        expect(screen.getByTestId(`${axis}-plus`)).toBeInTheDocument();
        expect(screen.getByTestId(`${axis}-minus`)).toBeInTheDocument();
      });
    });

    test('renders gripper controls', () => {
      expect(screen.getByTestId('gripper-controls')).toBeInTheDocument();
      expect(screen.getByTestId('gripper-open')).toBeInTheDocument();
      expect(screen.getByTestId('gripper-50')).toBeInTheDocument();
      expect(screen.getByTestId('gripper-close')).toBeInTheDocument();
    });

    test('renders position saving controls', () => {
      expect(screen.getByTestId('position-save')).toBeInTheDocument();
      expect(screen.getByTestId('position-name')).toBeInTheDocument();
      expect(screen.getByTestId('save-position')).toBeInTheDocument();
    });

    test('renders emergency controls', () => {
      expect(screen.getByTestId('emergency-controls')).toBeInTheDocument();
      expect(screen.getByTestId('home-button')).toBeInTheDocument();
      
      const emergencyStopBtn = screen.getByTestId('emergency-stop');
      expect(emergencyStopBtn).toBeInTheDocument();
      expect(emergencyStopBtn).toHaveStyle({ backgroundColor: 'red' });
    });

    test('displays current position', () => {
      expect(screen.getByTestId('current-position')).toBeInTheDocument();
      expect(screen.getByTestId('current-position')).toHaveTextContent('Current Position: X:0 Y:0 Z:0 A:0 B:0 C:0');
    });

    test('handles axis jog button interactions', async () => {
      const axis1Plus = screen.getByTestId('axis1-plus');
      const axis1Minus = screen.getByTestId('axis1-minus');
      
      // Test that buttons are clickable (no errors thrown)
      await user.click(axis1Plus);
      await user.click(axis1Minus);
      
      // Buttons should be enabled
      expect(axis1Plus).not.toBeDisabled();
      expect(axis1Minus).not.toBeDisabled();
    });

    test('handles gripper control interactions', async () => {
      await user.click(screen.getByTestId('gripper-open'));
      await user.click(screen.getByTestId('gripper-50'));

    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@react-three/drei": "^9.88.0",
    "@react-three/fiber": "^8.15.0",
    "@types/node": "^16.18.38",
    "@types/react": "^18.2.14",

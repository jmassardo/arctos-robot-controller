  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "npx react-scripts build --dry-run 2>&1 | grep -E '(warning|error)' || echo 'Frontend TypeScript compilation: PASSED'",
    "lint:fix": "npx react-scripts build --dry-run 2>&1 | grep -E '(warning|error)' || echo 'No lint issues found'",
    "lint:tsc": "npx tsc --noEmit",
    "analyze": "npm run build && npx serve -s build",
    "bundle-analyzer": "npm run build && npx webpack-bundle-analyzer build/static/js/*.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "identity-obj-proxy": "^3.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "playwright": "^1.55.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4"
  },

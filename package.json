{
  "name": "arctos-robot-controller",
  "version": "1.0.0",
  "description": "Desktop application for controlling multi-axis robotic arms",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "start": "node server.js",
    "dev": "npx nodemon server.js",
    "build": "cd client && npm run build",
    "install-client": "cd client && npm install",
    "electron": "npm run build && electron .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5000 && electron .\"",
    "electron-build": "npm run build && electron-builder",
    "dist": "npm run build && electron-builder --publish=never",
    "dist-all": "npm run build && electron-builder -mwl --publish=never",
    "lint": "npx eslint server.js lib/**/*.js --max-warnings 25",
    "lint:fix": "npx eslint server.js lib/**/*.js --fix --max-warnings 25",
    "format": "npx prettier --write \"**/*.{js,json,md}\"",
    "format:check": "npx prettier --check \"**/*.{js,json,md}\"",
    "quality:check": "npm run lint && npm run format:check && npm run test:unit",
    "quality:fix": "npm run lint:fix && npm run format",
    "prepare": "husky install || true",
    "quality:dashboard": "node scripts/quality-dashboard.js",
    "quality:full-fix": "node scripts/fix-quality-issues.sh && npm run format",
    "test": "node --test test/*.test.js",
    "test:unit": "node --test test/unit-tests/*.test.js",
    "test:unit:coverage": "npx c8 --reporter=text --reporter=html --reports-dir=./test-results/coverage node --test test/unit-tests/*.test.js",
    "test:comprehensive": "node test/comprehensive-test-runner.js",
    "test:comprehensive:parallel": "node test/comprehensive-test-runner.js --parallel",
    "test:frontend": "cd client && npm test -- --passWithNoTests --watchAll=false",
    "test:frontend:coverage": "cd client && npm test -- --coverage --passWithNoTests --watchAll=false",
    "test:e2e": "node e2e-tests/e2e-test-runner.js",
    "test:e2e:playwright": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:auth": "npx playwright test e2e-tests/auth-workflows.spec.ts",
    "test:e2e:control": "npx playwright test e2e-tests/robot-control-workflows.spec.ts",
    "test:e2e:realtime": "npx playwright test e2e-tests/realtime-multiuser-workflows.spec.ts",
    "test:e2e:mobile": "npx playwright test e2e-tests/cross-platform-mobile-workflows.spec.ts",
    "test:e2e:errors": "npx playwright test e2e-tests/error-recovery-edge-cases.spec.ts",
    "test:e2e:security": "npx playwright test e2e-tests/security-authorization.spec.ts",
    "test:e2e:chrome": "npx playwright test --project=desktop-chrome",
    "test:e2e:firefox": "npx playwright test --project=desktop-firefox",
    "test:e2e:safari": "npx playwright test --project=desktop-safari",
    "test:integration": "node test/integration-tests/integration-test-runner.js",
    "test:integration:parallel": "node test/integration-tests/integration-test-runner.js --parallel",
    "test:integration:verbose": "node test/integration-tests/integration-test-runner.js --verbose",
    "test:integration:comprehensive": "node test/integration-tests/comprehensive-integration-test-runner.js",
    "test:integration:comprehensive:parallel": "node test/integration-tests/comprehensive-integration-test-runner.js --parallel",
    "test:integration:comprehensive:verbose": "node test/integration-tests/comprehensive-integration-test-runner.js --verbose",
    "test:integration:error-recovery": "node --test test/integration-tests/error-recovery-integration-tests.js",
    "test:integration:performance": "node --test test/integration-tests/performance-integration-tests.js",
    "test:integration:api": "node --test test/integration-tests/api-contracts/api-contract-tests.js",
    "test:integration:db": "node --test test/integration-tests/database-integration/database-integration-tests.js",
    "test:integration:socket": "node --test test/integration-tests/socket-integration/socket-integration-tests.js",
    "test:integration:auth": "node --test test/integration-tests/auth-flow/auth-flow-integration-tests.js",
    "test:integration:hardware": "node --test test/integration-tests/hardware-integration/hardware-integration-tests.js",
    "test:performance": "node test/performance-tests/performance-test-runner.js",
    "test:performance:verbose": "node test/performance-tests/performance-test-runner.js --verbose",
    "test:performance:parallel": "node test/performance-tests/performance-test-runner.js --parallel",
    "test:performance:custom": "node test/performance-tests/performance-test-runner.js --output=./custom-perf-results",
    "test:perf:latency": "node -e \"const Test = require('./test/performance-tests/robot-control-latency.test.js'); new Test().run().then(r => console.log('Latency Tests:', r.success ? 'PASSED' : 'FAILED')).catch(e => console.error('Error:', e.message))\"",
    "test:perf:realtime": "node -e \"const Test = require('./test/performance-tests/realtime-communication.test.js'); new Test().run().then(r => console.log('Realtime Tests:', r.success ? 'PASSED' : 'FAILED')).catch(e => console.error('Error:', e.message))\"",
    "test:perf:load": "node -e \"const Test = require('./test/performance-tests/concurrent-user-load.test.js'); new Test().run().then(r => console.log('Load Tests:', r.success ? 'PASSED' : 'FAILED')).catch(e => console.error('Error:', e.message))\"",
    "test:perf:gcode": "node -e \"const Test = require('./test/performance-tests/gcode-processing.test.js'); new Test().run().then(r => console.log('G-code Tests:', r.success ? 'PASSED' : 'FAILED')).catch(e => console.error('Error:', e.message))\"",
    "test:perf:api": "node -e \"const Test = require('./test/performance-tests/api-response-time.test.js'); new Test().run().then(r => console.log('API Tests:', r.success ? 'PASSED' : 'FAILED')).catch(e => console.error('Error:', e.message))\"",
    "test:security": "node test/security-tests/comprehensive-security-runner.js",
    "test:security:owasp": "node --test test/security-tests/owasp-top10-security.test.js",
    "test:security:robot": "node --test test/security-tests/robot-security.test.js",
    "test:security:pentest": "node --test test/security-tests/penetration-testing.test.js",
    "test:security:dependencies": "node --test test/security-tests/dependency-security.test.js",
    "test:security:xss": "node --test test/security-tests/xss-security.test.js",
    "test:security:quick": "node --test test/security-tests/owasp-top10-security.test.js test/security-tests/robot-security.test.js",
    "test:all": "npm run test:comprehensive && npm run test:frontend:coverage && npm run test:integration && npm run test:e2e && npm run test:security",
    "test:watch": "node --test --watch test/unit-tests/*.test.js",
    "test:debug": "node --test --inspect test/unit-tests/*.test.js",
    "coverage": "npx c8 --reporter=text --reporter=json --reporter=html --reports-dir=./test-results/coverage npm run test:unit",
    "coverage:report": "npx c8 report --reporter=text --reporter=html",
    "docker:build": "docker build -t arctos-robot-controller:latest .",
    "docker:build-dev": "docker build -f Dockerfile.dev -t arctos-robot-controller:dev .",
    "docker:run": "docker run -p 5000:5000 arctos-robot-controller:latest",
    "docker:run-dev": "docker run -p 5000:5000 -p 3000:3000 -v $(pwd):/app arctos-robot-controller:dev",
    "docker:compose": "docker-compose up -d",
    "docker:compose-dev": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:compose-build": "docker-compose up --build -d",
    "docker:logs": "docker-compose logs -f",
    "docker:stop": "docker-compose down",
    "docker:clean": "docker-compose down -v --rmi all --remove-orphans"
  },
  "keywords": [
    "robotics",
    "control",
    "gcode",
    "servo",
    "can",
    "serial"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "bull": "^4.12.0",
    "cors": "^2.8.5",
    "dxf-parser": "^1.1.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "fs-extra": "^11.1.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^3.0.1",
    "modbus-serial": "^8.0.16",
    "multer": "^2.2.0",
    "node-cron": "^3.0.3",
    "path-exists": "^5.0.0",
    "qrcode": "^1.5.4",
    "sequelize": "^6.37.7",
    "serialport": "^12.0.0",
    "socket.io": "^4.7.2",
    "speakeasy": "^2.0.0",
    "sqlite3": "^5.1.7",
    "winston": "^3.11.0"
  },
  "optionalDependencies": {
    "socketcan": "^4.0.6"
  },
  "devDependencies": {
    "@axe-core/react": "^4.10.2",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.55.0",
    "axe-core": "^4.10.3",
    "axios": "^1.12.2",
    "c8": "^10.1.3",
    "commitlint": "^19.8.1",
    "concurrently": "^8.2.2",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "jest": "^30.1.3",
    "lighthouse": "^12.8.2",
    "lint-staged": "^16.1.6",
    "nodemon": "^3.1.10",
    "nyc": "^17.1.0",
    "pa11y": "^9.0.0",
    "playwright": "^1.55.0",
    "prettier": "^3.6.2",
    "socket.io-client": "^4.8.1",
    "supertest": "7.1.4",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.arctos.robot-controller",
    "productName": "Arctos Robot Controller",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "server.js",
      "client/build/**/*",
      "config/**/*",
      "data/**/*",
      "lib/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": "nsis"
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  }
}

{
  "name": "arctos-robot-controller",
  "version": "1.0.0",
  "description": "Web-based graphical interface to control multi-axis robotic arms",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "cd client && npm run build",
    "install-client": "cd client && npm install",
    "heroku-postbuild": "npm run install-client && npm run build"
  },
  "keywords": [
    "robotics",
    "control",
    "gcode",
    "servo",
    "can",
    "serial"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@serialport/parser-delimiter": "^13.0.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "fs-extra": "^11.1.1",
    "serialport": "^12.0.0",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}

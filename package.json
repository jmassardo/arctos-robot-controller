{
  "name": "arctos-robot-controller",
  "version": "1.0.0",
  "description": "Web-based graphical interface to control multi-axis robotic arms",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "cd client && npm run build",
    "install-client": "cd client && npm install",
    "heroku-postbuild": "npm run install-client && npm run build",
    "lint": "eslint server.js --fix",
    "test": "node --test test/*.test.js"
  },
  "keywords": [
    "robotics",
    "control",
    "gcode",
    "servo",
    "can",
    "serial"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "fs-extra": "^11.1.1",
    "socketcan": "^2.2.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "eslint": "^8.57.0"
  }
}
